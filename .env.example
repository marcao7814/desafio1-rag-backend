# ============================================================
# Provedor de LLM e Embeddings: "openai" ou "gemini"
# ============================================================
LLM_PROVIDER=openai

# ============================================================
# Credenciais OpenAI (necessárias se LLM_PROVIDER=openai)
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# Credenciais Gemini (necessárias se LLM_PROVIDER=gemini)
# ============================================================
GOOGLE_API_KEY=AIza...

# ============================================================
# Conexão com PostgreSQL (pgVector via Docker)
# ============================================================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ragdb

# ============================================================
# Nome da coleção no banco vetorial
# ============================================================
COLLECTION_NAME=documentos_rag

# ============================================================
# Caminho do PDF a ser ingerido
# ============================================================
PDF_PATH=document.pdf
